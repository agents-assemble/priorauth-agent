# Copy to .env and fill in. NEVER commit .env.

# -----------------------------------------------------------------------------
# LLM (Gemini via Google AI Studio — free tier)
# Each developer gets their own key from https://aistudio.google.com/app/apikey
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Placeholder — confirm exact model identifier on Day 1 of platform spike.

# -----------------------------------------------------------------------------
# MCP server
# -----------------------------------------------------------------------------
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PUBLIC_URL=
# Local: http://localhost:8000 or an ngrok URL during development
# Production: https://priorauth-mcp.fly.dev (or similar)

# -----------------------------------------------------------------------------
# A2A agent
# -----------------------------------------------------------------------------
A2A_HOST=0.0.0.0
A2A_PORT=8001
AGENT_PUBLIC_URL=
# Local: ngrok URL; Production: https://priorauth-agent.fly.dev (or similar)
AGENT_API_KEY=
# Random key used by Prompt Opinion middleware to authenticate calls to our A2A agent.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_SERVER_URL=
# A2A agent uses this to call our MCP server (same host as MCP_PUBLIC_URL).

# -----------------------------------------------------------------------------
# Prompt Opinion workspace FHIR (not a secret — informational)
# -----------------------------------------------------------------------------
FHIR_BASE_URL=
# Filled in by PO when our agent/MCP is invoked; this is here for local testing only.

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

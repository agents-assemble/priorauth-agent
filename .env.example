# Copy to .env and fill in. NEVER commit .env.

# =============================================================================
# LLM (Gemini via Google AI Studio — free tier)
# Each developer gets their own key from https://aistudio.google.com/app/apikey
# =============================================================================
GOOGLE_API_KEY=
# GA stable model — 15 RPM free tier, best rate-limit headroom.
# Preview alternative: gemini-3.1-flash-lite-preview (lower/unpublished limits).
GEMINI_MODEL=gemini-2.5-flash-lite
# Set to FALSE to use AI Studio free tier. Only TRUE if you have a Vertex AI project.
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# =============================================================================
# A2A agent (a2a_agent/)
# =============================================================================
# Random key PO uses to authenticate calls to our agent. Rotate per deployment.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENT_API_KEY=
# Comma-separated list alternative (either API_KEYS or AGENT_API_KEY is fine).
# API_KEYS=
# API_KEY_PRIMARY=
# API_KEY_SECONDARY=

# Public URL PO uses to reach THIS A2A agent (port 8001). No path — just the
# https base. The agent card's url + supportedInterfaces[].url are generated
# from this value at startup, so a change here requires restarting `make agent`.
#
#   Local dev via ngrok:  https://<subdomain>.ngrok-free.app   (from `make ngrok`)
#   Production on Fly.io: https://priorauth-agent.fly.dev
#
# IMPORTANT: This is the A2A agent's hostname (ngrok), NOT the MCP server's
# (cloudflared). When registering in a PO workspace, the External Agents UI
# gets this URL; the Server Hub gets MCP_SERVER_URL (below). See issue #17.
AGENT_PUBLIC_URL=
# Alias used by PO reference code when a single tunnel serves everything.
# BASE_URL=

# PO workspace URL — used to build the FHIR extension URI in our agent card.
# The FHIR metadata key PO sends is: {PO_PLATFORM_BASE_URL}/schemas/a2a/v1/fhir-context
PO_PLATFORM_BASE_URL=https://app.promptopinion.ai

# Full URL the A2A agent uses to reach the MCP server (port 8000) — MUST
# include the /mcp JSON-RPC path and MUST be distinct from AGENT_PUBLIC_URL
# when registered against a live PO workspace (see issue #17).
#
#   Local dev, same machine:            http://localhost:8000/mcp
#   Local dev via cloudflared tunnel:    https://<random>.trycloudflare.com/mcp
#   Production on Fly.io:               https://priorauth-mcp.fly.dev/mcp
MCP_SERVER_URL=

# =============================================================================
# MCP server (mcp_server/)
# =============================================================================
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_PUBLIC_URL=
# Comma-separated CORS allow-list. Default "*" is fine for local dev + the
# hackathon demo. Tighten to the PO workspace origin(s) + our Fly.io app URL
# before any public deployment that handles real PHI-adjacent tokens.
MCP_ALLOWED_ORIGINS=*

# =============================================================================
# Observability (optional)
# =============================================================================
LOG_LEVEL=INFO
# Log full JSON-RPC body on every request (default true). Set false in production.
LOG_FULL_PAYLOAD=true
# Dump raw ADK callback objects — debug only.
LOG_HOOK_RAW_OBJECTS=false

# =============================================================================
# ngrok (local dev only — never in production)
# Sign up at https://dashboard.ngrok.com, copy your auth token here.
# =============================================================================
NGROK_AUTHTOKEN=
